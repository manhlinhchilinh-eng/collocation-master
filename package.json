{
  "name": "collocation-master",
  "version": "1.0.0",
  "description": "Collocation learning platform with spaced repetition for THPT Chuyên Ngoại ngữ",
  "main": "server/server.js",
  "scripts": {
    "dev:server": "node server/server.js",
    "dev:client": "cd client && npx vite --port 5173",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm install && npx vite build --outDir ../server/public",
    "start": "node server/server.js",
    "seed": "node server/seed/seedData.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sql.js": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "cookie-parser": "^1.4.6",
    "express-validator": "^7.0.1",
    "concurrently": "^8.2.2"
  }
}
